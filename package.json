{
  "name": "inletbase",
  "version": "2.0.1",
  "description": "Securely submit forms and integrate real-time AI chatbots into any frontend with Inletbase.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify-pack": "node scripts/verify-pack.mjs",
    "prepublishOnly": "npm run build && node scripts/verify-pack.mjs"
  },
  "files": [
    "dist",
    "dist/widget/inletbase-chat.js"
  ],
  "keywords": [
    "inletbase",
    "forms",
    "form-builder",
    "react",
    "chatbot",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byteonic-Labs/inletbase.git"
  },
  "bugs": {
    "url": "https://github.com/Byteonic-Labs/inletbase/issues"
  },
  "homepage": "https://inletbase.com",
  "peerDependencies": {
    "react": ">=16.8"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "fast-check": "^3.23.2",
    "jsdom": "^25.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  },
  "author": "Byteonic Labs",
  "license": "ISC"
}
